# Pokemon TCG Developers API key — https://dev.pokemontcg.io
# Optional. Without a key the app works at 1 000 requests/day (unauthenticated limit).
# With a free key the limit rises to 20 000 requests/day.
# Copy this file to .env.local and fill in your key. Never commit .env.local.
VITE_POKEMON_TCG_API_KEY=

# LLM vision key — used as fallback when local pHash matching is low-confidence.
# If both are set, VITE_OPENAI_API_KEY takes precedence over VITE_ANTHROPIC_API_KEY.
# If neither is set the app runs in local-only mode (pHash matching only).
VITE_OPENAI_API_KEY=
VITE_ANTHROPIC_API_KEY=
